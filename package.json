{
  "name": "northlight-panel",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "check:rust:debug": "cargo check --manifest-path src-tauri/Cargo.toml --features debug-diagnostics",
    "build:windows": "tauri build --target x86_64-pc-windows-gnu",
    "build:windows:debug": "tauri build --target x86_64-pc-windows-gnu --features debug-diagnostics",
    "build:windows-gnu": "npm run build:windows",
    "release:zip": "cargo run --manifest-path src-tauri/Cargo.toml --example export-release",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:debug-diagnostics": "tauri dev --features debug-diagnostics"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "@tauri-apps/cli": "^2"
  }
}
